{
    "configs": {
        "arcgis_rest": {
            "base_search_url": "https://data.gis.ny.gov/search?categories=%2Fcategories%2F",
            "selectors": {
                "catalog_container": "arcgis-hub-catalog",
                "gallery_card": {
                    "query": "arcgis-hub-entity-card[data-test='{SEARCH_TERM}']",
                    "path": ["arcgis-hub-gallery", "arcgis-hub-gallery-layout-list"]
                },
                "details_page": {
                    "api_resources_button": "button[data-test='apiResources']",
                    "fallback_api_selector": "a[data-test='dataSource']"
                }
            }
        },
        "web_dom_land": {
            "base_url": "https://www.land.com/New-York/all-land/for-sale/over-100-acres/is-active/type-179/",
            "selectors": {
                "listing_container": "div[data-qa-placard]",
                "info_container": "div[data-qa-placardinfo='true']",
                "property_link": "a[href*='/property/']",
                "address_selector": "p",
                "price_selector": "span"
            }
        }
    },
    "source_definitions": [
        {
            "name": "NYS_GIS_Portal",
            "type": "arcgis_rest",
            "categories": [
                {
                    "category": "water",
                    "datasets": [{ "id": "nys_dams", "search_term": "Dams", "imported": true }]
                }
            ]
        },
        {
            "name": "Land_Com_Market",
            "type": "web_dom_land",
            "datasets": [
                {
                    "id": "land_ny_100_plus",
                    "search_term": "100+ Acre Tracts",
                    "imported": false,
                    "scraped_url": ""
                }
            ]
        }
    ]
}